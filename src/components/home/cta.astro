---
import "../../../public/assets/style/cta.css";
const { lang, t } = Astro.props;
---

<section class="cta-section" id="ctaSection">
  <!-- Floating Parallax Fruit -->
  <img
    class="parallax-fruit lazy-img"
    id="fruitLeft"
    style="left: 5%; top: 20%;"
    data-src="https://pngimg.com/uploads/strawberry/strawberry_PNG2595.png"
    alt="Expo lukus strawberry"
    width="300"
    height="300"
  />
  <img
    class="parallax-fruit lazy-img"
    id="fruitRight"
    style="right: 5%; bottom: 10%;"
    data-src="https://pngimg.com/uploads/apple/apple_PNG12439.png"
    alt="Expo lukus apple"
    width="300"
    height="300"
  />

  <div class="container-70">
    <!-- Left Side -->
    <div class="cta-text">
      <span
        style="color:var(--white); font-weight:800; letter-spacing:5px; text-transform:uppercase; font-size:12px;"
      >
        {t("cta").tag}
      </span>

      <h2 set:html={t("cta").title} />

      <p>{t("cta").description}</p>
    </div>

    <!-- Right Side -->
    <div class="cta-form-wrap" id="formReveal">
      <form>
        <div class="form-group">
          <input type="text" id="name" required />
          <label>{t("cta").form.name}</label>
          <div class="liquid-line"></div>
        </div>

        <div class="form-group">
          <input type="email" id="email" required />
          <label>{t("cta").form.email}</label>
          <div class="liquid-line"></div>
        </div>

        <div class="form-group">
          <textarea id="message" rows="3" required></textarea>
          <label>{t("cta").form.message}</label>
          <div class="liquid-line"></div>
        </div>

        <div style="text-align: right;">
          <button type="submit" class="submit-btn" id="magBtn">
            {t("cta").form.submit}
          </button>
        </div>
      </form>
    </div>
  </div>
</section>

<script>
  gsap.registerPlugin(ScrollTrigger);

  const section = document.querySelector("#ctaSection");

  // 1. BACKGROUND COLOR BLEED (The Vibe Shift)
  ScrollTrigger.create({
    trigger: section,
    start: "top 60%",
    onEnter: () => section.classList.add("dark-vibe"),
    onLeaveBack: () => section.classList.remove("dark-vibe"),
  });

  // 2. FORM STAGGER ENTRANCE
  gsap.from("#formReveal", {
    y: 100,
    opacity: 0,
    duration: 1.2,
    ease: "power4.out",
    scrollTrigger: {
      trigger: "#formReveal",
      start: "top 85%",
    },
  });

  // 3. PARALLAX FRUITS
  gsap.to("#fruitLeft", {
    y: -200,
    rotate: 15,
    scrollTrigger: {
      trigger: section,
      scrub: 1,
    },
  });

  gsap.to("#fruitRight", {
    y: -300,
    rotate: -15,
    scrollTrigger: {
      trigger: section,
      scrub: 1,
    },
  });

  // 4. MAGNETIC BUTTON
  const btn = document.querySelector("#magBtn");
  btn.addEventListener("mousemove", (e) => {
    const rect = btn.getBoundingClientRect();
    const x = e.clientX - rect.left - rect.width / 2;
    const y = e.clientY - rect.top - rect.height / 2;
    gsap.to(btn, { x: x * 0.3, y: y * 0.3, duration: 0.4 });
  });
  btn.addEventListener("mouseleave", () => {
    gsap.to(btn, { x: 0, y: 0, duration: 0.6, ease: "elastic.out(1, 0.7)" });
  });
</script>
