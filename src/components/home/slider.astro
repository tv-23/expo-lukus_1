---
import "../../../public/assets/style/slider.css";
---

<div class="slider" id="mainSlider">
    <div class="bg-container" id="bgContainer"></div>

    <div class="content-wrapper">
        <div class="top-title-mask">
            <div class="top-title" id="topTitle"></div>
        </div>

        <div class="frame-box">
            <svg class="frame-svg" viewBox="0 0 450 550">
                <path id="pathA" class="painting-line" d=""></path>
                <path id="pathB" class="painting-line" d=""></path>
            </svg>

            <div class="mask">
                <h1 class="main-title" id="mainTitle"></h1>
            </div>

            <div class="mask">
                <p class="subtitle" id="subtitle"></p>
            </div>
        </div>
    </div>

    <button class="nav-btn prev-btn">&#8249;</button>
    <button class="nav-btn next-btn">&#8250;</button>
    <div class="dots" id="dots"></div>
</div>

<script>
    window.addEventListener("DOMContentLoaded", () => {
        const path = window.location.pathname.toLowerCase();

        // If URL starts with /en or /en/...
        const lang = path === "/en" || path.startsWith("/en/") ? "EN" : "ES";

        const translations = {
            EN: [
                {
                    top: "Premium Quality",
                    main: "Fresh Herbs",
                    sub: "Aromatic fresh herbs exported by Expo Lukus for premium global markets.",
                    img: "/assets/images/slider/1.webp",
                },
                {
                    top: "Carefully Selected",
                    main: "Fresh Vegetables",
                    sub: "Fresh vegetables carefully selected and exported by Expo Lukus.",
                    img: "/assets/images/slider/2.webp",
                },
                {
                    top: "Export Excellence",
                    main: "Fresh Fruits",
                    sub: "Premium fresh fruits exported by Expo Lukus with top export quality standards.",
                    img: "/assets/images/slider/3.webp",
                },
            ],
            ES: [
                {
                    top: "Calidad Premium",
                    main: "Hierbas Frescas",
                    sub: "Hierbas frescas aromáticas exportadas por Expo Lukus para mercados globales premium.",
                    img: "/assets/images/slider/1.webp",
                },
                {
                    top: "Selección Cuidadosa",
                    main: "Verduras Frescas",
                    sub: "Verduras frescas cuidadosamente seleccionadas y exportadas por Expo Lukus.",
                    img: "/assets/images/slider/2.webp",
                },
                {
                    top: "Excelencia en Exportación",
                    main: "Frutas Frescas",
                    sub: "Frutas frescas de alta calidad exportadas por Expo Lukus con estándares internacionales.",
                    img: "/assets/images/slider/3.webp",
                },
            ],
        };

        // fallback safety
        const slides = translations[lang] || translations["ES"];

        document
            .querySelector(".prev-btn")
            .addEventListener("click", () => handleNav(-1));
        document
            .querySelector(".next-btn")
            .addEventListener("click", () => handleNav(1));

        let currentIndex = 0;
        let isAnimating = false;
        let autoPlayTimer;
        const slideDuration = 8000; // Total time per slide (includes slow animation)

        const strokeWidth = 7.5;
        const W = 450 - strokeWidth;
        const H = 550 - strokeWidth;
        const S = strokeWidth;

        function setPathDirection(mode) {
            const pA = document.getElementById("pathA");
            const pB = document.getElementById("pathB");
            if (mode === "next") {
                pA.setAttribute("d", `M ${S},${S} H ${W} V ${H}`);
                pB.setAttribute("d", `M ${S},${S} V ${H} H ${W}`);
            } else {
                pA.setAttribute("d", `M ${W},${H} H ${S} V ${S}`);
                pB.setAttribute("d", `M ${W},${H} V ${S} H ${S}`);
            }
        }

        const bgContainer = document.getElementById("bgContainer");
        const dotsContainer = document.getElementById("dots");
        slides.forEach((s, i) => {
            const div = document.createElement("div");
            div.className = `slide-bg ${i === 0 ? "active" : ""}`;

            // ✅ Create image instead of background-image
            const img = document.createElement("img");
            img.alt = "Expo Lukus - "+s.main;
            let lazy = ""
            // ✅ LCP optimization
            if (i === 0) {
                img.loading = "eager";
                img.fetchPriority = "high";
            img.src = s.img;

            } else {
                img.loading = "lazy";
            img.dataset.src = s.img;
            lazy = "lazy-img"
            }

            img.className = "slide-img "+lazy;


            div.appendChild(img);
            bgContainer.appendChild(div);

            // ✅ KEEP DOTS (unchanged logic)
            const dot = document.createElement("div");
            dot.className = `dot ${i === 0 ? "active" : ""}`;

            dot.onclick = () => {
                if (!isAnimating && i !== currentIndex) {
                    animateTo(i, i > currentIndex ? 1 : -1);
                }
            };

            dotsContainer.appendChild(dot);
        });

        function updateDOM(index) {
            document.getElementById("topTitle").innerText = slides[index].top;
            document.getElementById("mainTitle").innerHTML = slides[index].main;
            document.getElementById("subtitle").innerText = slides[index].sub;
            document
                .querySelectorAll(".dot")
                .forEach((d, i) => d.classList.toggle("active", i === index));
            document
                .querySelectorAll(".slide-bg")
                .forEach((b, i) => b.classList.toggle("active", i === index));
        }

        function animateTo(nextIndex, step) {
            isAnimating = true;
            resetTimer();
            const dir = step > 0 ? "next" : "prev";
            const tl = gsap.timeline({
                onComplete: () => {
                    currentIndex = nextIndex;
                    isAnimating = false;
                },
            });

            // EXIT PHASE (Increased by 40%)
            tl.to("#topTitle", {
                yPercent: dir === "next" ? 100 : -100,
                opacity: 0,
                duration: 0.56,
            });
            tl.to(
                "#mainTitle",
                {
                    xPercent: dir === "next" ? 100 : -100,
                    opacity: 0,
                    duration: 0.56,
                },
                "-=0.42",
            );
            tl.to(
                ".painting-line",
                {
                    strokeDashoffset: 1200,
                    duration: 0.84,
                    ease: "power2.inOut",
                },
                "-=0.56",
            );
            tl.to("#subtitle", { opacity: 0, duration: 0.28 }, "-=0.7");

            // SWAP DATA
            tl.call(() => {
                updateDOM(nextIndex);
                setPathDirection(dir);
            });

            // ENTRANCE PHASE (Painting now 1.4s, Titles increased by 40%)
            tl.set("#topTitle", {
                yPercent: dir === "next" ? -100 : 100,
                opacity: 0,
            });
            tl.set("#mainTitle", {
                xPercent: dir === "next" ? -100 : 100,
                opacity: 0,
            });
            tl.set(".painting-line", { strokeDashoffset: 1200 });

            tl.to(".painting-line", {
                strokeDashoffset: 0,
                duration: 1.4,
                ease: "power2.inOut",
            });
            tl.to(
                "#topTitle",
                { yPercent: 0, opacity: 1, duration: 0.84, ease: "power2.out" },
                "-=0.98",
            );
            tl.to(
                "#mainTitle",
                { xPercent: 0, opacity: 1, duration: 0.98, ease: "power2.out" },
                "-=0.7",
            );
            tl.to("#subtitle", { opacity: 1, duration: 0.56 }, "-=0.42");
        }

        function handleNav(step) {
            if (isAnimating) return;
            let next = currentIndex + step;
            if (next >= slides.length) next = 0;
            if (next < 0) next = slides.length - 1;
            animateTo(next, step);
        }

        function startTimer() {
            autoPlayTimer = setInterval(() => {
                if (!isAnimating) handleNav(1);
            }, slideDuration);
        }

        function resetTimer() {
            clearInterval(autoPlayTimer);
            startTimer();
        }

        const mainSlider = document.getElementById("mainSlider");
        mainSlider.addEventListener("mouseenter", () =>
            clearInterval(autoPlayTimer),
        );
        mainSlider.addEventListener("mouseleave", () => startTimer());

        window.onload = () => {
            updateDOM(0);
            setPathDirection("next");
            // Initial Entry (Slower)
            gsap.to(".painting-line", { strokeDashoffset: 0, duration: 2.1 });
            gsap.from("#topTitle", {
                yPercent: -100,
                opacity: 0,
                duration: 1.4,
            });
            gsap.from("#mainTitle", {
                xPercent: -100,
                opacity: 0,
                duration: 1.4,
                delay: 0.42,
            });
            setTimeout(() => {
                startTimer();
            }, 50);
        };
    });


</script>
