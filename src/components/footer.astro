---
import "../../public/assets/style/footer.css";
const { lang, t } = Astro.props;
---

<footer id="expo-footer">
    <div class="footer-watermark" id="watermark"></div>

    <div class="container-70" id="footerReveal">
        <div class="footer-top">
            <div class="footer-brand">
                <a href="/">
                    <img src="/assets/images/logo white.svg" alt="Expo Lukus" />
                </a>

                <p>{t("footer").description}</p>
            </div>

            <div class="footer-socials">
                <div class="social-circle">
                    <a href=""><i class="fa-brands fa-facebook"></i></a>
                </div>
                <div class="social-circle">
                    <a href=""><i class="fa-brands fa-instagram"></i></a>
                </div>
                <div class="social-circle">
                    <a href=""><i class="fa-brands fa-linkedin-in"></i></a>
                </div>
            </div>
        </div>

        <div class="footer-grid">
            <!-- Navigation -->
            <div class="footer-col">
                <h4>{t("footer").explore}</h4>
                <ul>
                    <li><a href="/">{t("footer").links.home}</a></li>
                    <li><a href="/about">{t("footer").links.about}</a></li>
                    <li>
                        <a href="/products">{t("footer").links.products}</a>
                    </li>
                    <li><a href="/contact">{t("footer").links.contact}</a></li>
                </ul>
            </div>

            <!-- Morocco Hub -->
            <div class="footer-col">
                <h4>{t("footer").moroccoHub}</h4>
                <span class="hub-tag">{t("footer").hub.sourcing}</span>
                <ul>
                    <li><a href="#">Expo Lukus</a></li>
                    <li><a href="#">Larache, Morocco</a></li>
                    <li><a href="tel:+212662361174">+212 662 361 174</a></li>
                </ul>
            </div>

            <!-- Spain Hub -->
            <div class="footer-col">
                <h4>{t("footer").spainHub}</h4>
                <span class="hub-tag">{t("footer").hub.logistics}</span>
                <ul>
                    <li><a href="#">Chetouan Import Export</a></li>
                    <li><a href="#">Madrid, Spain</a></li>
                    <li><a href="tel:+3400000000">+34 91 000 000</a></li>
                </ul>
            </div>

            <!-- Legal -->
            <div class="footer-col">
                <h4>{t("footer").legal}</h4>
                <ul>
                    <li><a href="#">{t("footer").links.privacy}</a></li>
                    <li><a href="#">{t("footer").links.terms}</a></li>
                    <li><a href="#">{t("footer").links.licenses}</a></li>
                </ul>
            </div>
        </div>

        <div class="footer-bottom">
            <div set:html={t("footer").copyright}/>
                
            <div
                style="text-transform: uppercase; letter-spacing: 2px;"
                set:html={t("footer").tagline}
            />
        </div>
    </div>
</footer>

<script>
    window.addEventListener("load", () => {

    gsap.registerPlugin(ScrollTrigger);

    // 1. FOOTER CONTENT REVEAL
    // Everything inside the 70% container rises smoothly
    gsap.from("#footerReveal", {
        y: 100,
        opacity: 0,
        duration: 1.5,
        ease: "power4.out",
        scrollTrigger: {
            trigger: "footer",
            start: "top 90%",
        },
    });

    // 2. PARALLAX WATERMARK
    // The big background text moves at a different speed
    gsap.from("#watermark", {
        y: 200,
        opacity: 0,
        duration: 2,
        ease: "power3.out",
        scrollTrigger: {
            trigger: "footer",
            start: "top bottom",
            scrub: 1,
        },
    });

    // 3. MAGNETIC SOCIAL ICONS
    const socials = document.querySelectorAll(".social-circle");
    socials.forEach((icon) => {
        icon.addEventListener("mousemove", (e) => {
            const rect = icon.getBoundingClientRect();
            const x = e.clientX - rect.left - rect.width / 2;
            const y = e.clientY - rect.top - rect.height / 2;
            gsap.to(icon, { x: x * 0.5, y: y * 0.5, duration: 0.4 });
        });
        icon.addEventListener("mouseleave", () => {
            gsap.to(icon, {
                x: 0,
                y: 0,
                duration: 0.6,
                ease: "elastic.out(1, 0.7)",
            });
        });
    });
});
</script>
