---
const { product, lang } = Astro.props;
import "../../public/assets/style/product-detail.css";

export async function getStaticPaths() {
    const products = Object.keys(productDetails);
    const langs = ["en", "es"];

    return langs.flatMap((lang) =>
        products.map((id) => ({
            params: { lang, id },
        })),
    );
}
---

<div class="detail-wrapper" id="ExpoLukusProdcutDeatils">
    <!-- LEFT: GALLERY -->
    <div class="gallery-pane">
        <div class="main-fruit-wrap">
            <div class="bg-circle" id="circle"></div>
            <!-- High-res Mint Image -->
            <img
                src={product.image}
                alt="Fresh Mint"
                class="fruit-img"
                id="productImg"
            />
        </div>
    </div>

    <!-- RIGHT: INFO -->
    <div class="info-pane">
        <!-- <div class="ghost-bg" id="ghostText">FRESH</div> -->
        <span class="category-label">{product.category[lang]}</span>
        <h1>{product.title[lang]}</h1>

        <p class="description">
            {product.description[lang]}
        </p>

        <div class="packaging-section">
            <h4>Packaging Options</h4>
            <div class="packaging-grid">
                {
                    product.packaging.map((pack) => (
                        <div class="pack-item">
                            <div class="pack-weight">{pack.weight}</div>
                            <div class="pack-detail">{pack.detail[lang]}</div>
                        </div>
                    ))
                }
            </div>
        </div>

        <a href="/contact" class="contact-trigger" id="magneticBtn">
            {lang === "en" ? "Place Enquiry" : "Solicitar Pedido"}
        </a>
    </div>
</div>

<script>
    gsap.registerPlugin(ScrollTrigger);

    // 1. Entrance Animation
    const tl = gsap.timeline();

    // 2. Sticky Image Parallax & Rotation on Scroll
    gsap.to("#productImg", {
        rotation: 15,
        y: 50,
        scale: 1.1,
        scrollTrigger: {
            trigger: ".detail-wrapper",
            start: "top top",
            end: "bottom bottom",
            scrub: 1,
        },
    });

    // 3. Ghost Text Parallax
    gsap.to("#ghostText", {
        x: 100,
        scrollTrigger: {
            trigger: ".detail-wrapper",
            scrub: 2,
        },
    });

    // 4. Background Circle Pulse
    gsap.to("#circle", {
        scale: 1.2,
        opacity: 0.5,
        duration: 3,
        repeat: -1,
        yoyo: true,
        ease: "sine.inOut",
    });

    // 5. Magnetic Button Effect
    const btn = document.querySelector("#magneticBtn");
    btn.addEventListener("mousemove", (e) => {
        const rect = btn.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;

        gsap.to(btn, {
            x: x * 0.3,
            y: y * 0.3,
            duration: 0.5,
            ease: "power2.out",
        });
    });

    btn.addEventListener("mouseleave", () => {
        gsap.to(btn, {
            x: 0,
            y: 0,
            duration: 0.7,
            ease: "elastic.out(1, 0.75)",
        });
    });
</script>
