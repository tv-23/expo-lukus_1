---
import "../../../public/assets/style/about.css";

const { lang, t } = Astro.props;
---

  <section class="about-container">
        <!-- This is the element we will PIN -->
        <div class="about-content-inner" id="pinTarget">
            
            <h2 class="about-headline" id="mainHeadline"> {t("about.headline").p1}<br> {t("about.headline").p2}</h2>

            <!-- Hidden Core Content -->
            <div class="about-text" id="coreContent">
                <h3>Expo Lukus</h3>
                <p>
                   {t("about.text")}
                </p>
            </div>

            <!-- The Fruit -->
            <div class="fruit-box" id="fruitBox">
                <div class="fruit-half half-left" id="lHalf"></div>
                <div class="fruit-half half-right" id="rHalf"></div>
            </div>

        </div>
    </section>

<script>
        gsap.registerPlugin(ScrollTrigger);

        // Generate dots
        const pinTarget = document.getElementById('pinTarget');
        const points = [];
        for(let i=0; i<12; i++) {
            const dot = document.createElement('div');
            dot.className = 'point';
            pinTarget.appendChild(dot);
            points.push(dot);
        }

        // MAIN TIMELINE
        const tl = gsap.timeline({
            scrollTrigger: {
                trigger: ".about-container",
                start: "top top",      // Start when the top of the container hits the top of the viewport
                end: "+=3000",         // Duration of the scroll (adjust for speed)
                pin: "#pinTarget",     // PIN THE INNER CONTENT
                scrub: 1,              // Smooth scroll
                pinSpacing: true,      // Ensures the next section stays below
                anticipatePin: 1
            }
        });

        // ANIMATION STEPS
        // 1. Headline appears
        tl.to("#mainHeadline", { opacity: 1, y: 0, duration: 1 });

        // 2. Fruit opens & dots fly out
        tl.to("#lHalf", { xPercent: -150, rotate: -15, duration: 3 }, 1);
        tl.to("#rHalf", { xPercent: 150, rotate: 15, duration: 3 }, 1);

        points.forEach((dot, i) => {
            tl.to(dot, {
                opacity: 1,
                x: (Math.random() - 0.5) * 500,
                y: (Math.random() - 0.5) * 500,
                scale: Math.random() * 1.5,
                duration: 2,
            }, 1.2 + (i * 0.1));
        });

        // 3. Reveal Text / Hide Headline
        tl.to("#mainHeadline", { opacity: 0, y: -50, duration: 1 }, 1.5);
        tl.to("#coreContent", { opacity: 1, scale: 1, duration: 2 }, 2);

        // 4. Fade dots out at the end
        tl.to(".point", { opacity: 0, duration: 1 }, 3);

    </script>