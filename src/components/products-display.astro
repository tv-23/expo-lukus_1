---
import "../../public/assets/style/products-display.css";
const { lang, t } = Astro.props;
---

<section class="products-section">
    <div class="container">
        <div class="section-header">
            <div class="filter-wrapper">
                <button class="filter-btn active" data-filter="all"
                    >{t("products.filter.all")}</button
                >
                <button class="filter-btn" data-filter="fresh-herbs"
                    >{t("products.filter.fresh-herbs")}</button
                >
                <button class="filter-btn" data-filter="fresh-vegetables"
                    >{t("products.filter.fresh-vegetables")}</button
                >
                <button class="filter-btn" data-filter="fresh-fruits"
                    >{t("products.filter.fresh-fruits")}</button
                >
            </div>
        </div>

        <div class="product-grid" id="productGrid">
            <!-- 12 PRODUCTS -->
            <div class="product-card" data-category="fresh-vegetables">
                <div class="card-inner">
                    <div class="image-box">
                        <span class="badge">Year-round</span>
                        <img
                            src="https://pngimg.com/uploads/apple/apple_PNG12439.png"
                            class="fruit-img"
                        />
                    </div>
                    <div class="card-content">
                        <p class="origin">USA</p>
                        <h3>Royal Gala</h3>
                        <p>Premium grade apples with exceptional sweetness.</p>
                        <a href="/product-detail"
                            ><button class="enquiry-btn">Bulk Enquiry</button
                            ></a
                        >
                    </div>
                </div>
            </div>

            <div class="product-card" data-category="fresh-herbs">
                <div class="card-inner">
                    <div class="image-box">
                        <span class="badge">Apr - Jun</span>
                        <span class="badge seasonal">Seasonal</span>
                        <img
                            src="https://pngimg.com/uploads/mango/mango_PNG9176.png"
                            class="fruit-img"
                        />
                    </div>
                    <div class="card-content">
                        <p class="origin">India</p>
                        <h3>Alphonso</h3>
                        <p>
                            Hand-picked "King of Mangoes" from the Ratnagiri
                            belt.
                        </p>
                        <a href="/product-detail"
                            ><button class="enquiry-btn">Bulk Enquiry</button
                            ></a
                        >
                    </div>
                </div>
            </div>

            <div class="product-card" data-category="fresh-vegetables">
                <div class="card-inner">
                    <div class="image-box">
                        <span class="badge">Year-round</span>
                        <img
                            src="https://pngimg.com/uploads/banana/banana_PNG843.png"
                            class="fruit-img"
                        />
                    </div>
                    <div class="card-content">
                        <p class="origin">Ecuador</p>
                        <h3>Cavendish</h3>
                        <p>
                            Export-ready bananas harvested for maximum shelf
                            life.
                        </p>
                        <a href="/product-detail"
                            ><button class="enquiry-btn">Bulk Enquiry</button
                            ></a
                        >
                    </div>
                </div>
            </div>

            <div class="product-card" data-category="fresh-herbs">
                <div class="card-inner">
                    <div class="image-box">
                        <span class="badge">Nov - Mar</span>
                        <span class="badge seasonal">Seasonal</span>
                        <img
                            src="https://pngimg.com/uploads/orange/orange_PNG780.png"
                            class="fruit-img"
                        />
                    </div>
                    <div class="card-content">
                        <p class="origin">Spain</p>
                        <h3>Valencia Orange</h3>
                        <p>Vibrant citrus, high in juice and natural sugars.</p>
                        <a href="/product-detail"
                            ><button class="enquiry-btn">Bulk Enquiry</button
                            ></a
                        >
                    </div>
                </div>
            </div>

            <div class="product-card" data-category="fresh-vegetables">
                <div class="card-inner">
                    <div class="image-box">
                        <span class="badge">Year-round</span>
                        <img
                            src="https://pngimg.com/uploads/lemon/lemon_PNG38.png"
                            class="fruit-img"
                        />
                    </div>
                    <div class="card-content">
                        <p class="origin">Turkey</p>
                        <h3>Eureka Lemon</h3>
                        <p>High-acidity lemons, perfect for commercial use.</p>
                        <a href="/product-detail"
                            ><button class="enquiry-btn">Bulk Enquiry</button
                            ></a
                        >
                    </div>
                </div>
            </div>

            <div class="product-card" data-category="fresh-herbs">
                <div class="card-inner">
                    <div class="image-box">
                        <span class="badge">Jun - Aug</span>
                        <span class="badge seasonal">Seasonal</span>
                        <img
                            src="https://pngimg.com/uploads/strawberry/strawberry_PNG2595.png"
                            class="fruit-img"
                        />
                    </div>
                    <div class="card-content">
                        <p class="origin">Mexico</p>
                        <h3>Red Diamond</h3>
                        <p>Succulent strawberries grown in volcanic soil.</p>
                        <a href="/product-detail"
                            ><button class="enquiry-btn">Bulk Enquiry</button
                            ></a
                        >
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    gsap.registerPlugin(ScrollTrigger);

    const allCards = document.querySelectorAll(".product-card");
    const xxx = document.querySelector("#productGrid");
    const filterBtns = document.querySelectorAll(".filter-btn");

    /* Staircase */
    function calculateStaircase(animate = true) {
        let visibleIndex = 0;

        allCards.forEach((card) => {
            if (window.getComputedStyle(card).display !== "none") {
                const offset = visibleIndex * 20;

                // 1. Visual animation
                gsap.to(card, {
                    y: offset,
                    duration: animate ? 0.8 : 0,
                    ease: "power3.out",
                    overwrite: true,
                });

                // 2. Real spacing
                xxx.style.marginBottom = offset + "px";

                visibleIndex++;
            } else {
                xxx.style.marginBottom = "0px";
            }
        });

        setTimeout(() => ScrollTrigger.refresh(), 100);
    }

    /* Entrance */
    function initEntrance() {
        gsap.from(allCards, {
            opacity: 0,
            scale: 0.8,
            y: 100,
            stagger: 0.1,
            duration: 1.2,
            ease: "expo.out",
            onComplete: () => calculateStaircase(true),
            scrollTrigger: {
                trigger: ".product-grid",
                start: "top 85%",
            },
        });
    }

    /* Filter */
    filterBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
            const filter = btn.dataset.filter;

            filterBtns.forEach((b) => b.classList.remove("active"));
            btn.classList.add("active");

            gsap.to(allCards, {
                scale: 0.5,
                opacity: 0,
                duration: 0.3,
                stagger: 0.02,
                onComplete: () => {
                    allCards.forEach((card) => {
                        if (
                            filter === "all" ||
                            card.dataset.category === filter
                        ) {
                            gsap.set(card, { display: "block" });
                        } else {
                            gsap.set(card, { display: "none" });
                        }
                    });

                    calculateStaircase(false);

                    const visibleCards = Array.from(allCards).filter(
                        (c) => window.getComputedStyle(c).display !== "none",
                    );

                    gsap.to(visibleCards, {
                        scale: 1,
                        opacity: 1,
                        duration: 0.6,
                        stagger: 0.08,
                        ease: "back.out(1.2)",
                        onComplete: () => calculateStaircase(true),
                    });
                },
            });
        });
    });

    window.addEventListener("load", initEntrance);
</script>
