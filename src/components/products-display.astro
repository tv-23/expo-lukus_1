<script>
    gsap.registerPlugin(ScrollTrigger);
    
    const allCards = document.querySelectorAll('.product-card');
    const xxx = document.querySelectorAll('#productGrid');
    const filterBtns = document.querySelectorAll('.filter-btn');
    
    /* Staircase */
    function calculateStaircase(animate = true) {
    let visibleIndex = 0;

    allCards.forEach(card => {
        if (window.getComputedStyle(card).display !== 'none') {

            const offset = visibleIndex * 20;

            // 1. Visual animation
            gsap.to(card, {
                y: offset,
                duration: animate ? 0.8 : 0,
                ease: "power3.out",
                overwrite: true
            });

            // 2. Real spacing
            xxx.style.marginBottom = offset + "px";

            visibleIndex++;
        } else {
            xxx.style.marginBottom = "0px";
        }
    });

    setTimeout(() => ScrollTrigger.refresh(), 100);
}
    
    /* Entrance */
    function initEntrance() {
        gsap.from(allCards, {
            opacity: 0,
            scale: 0.8,
            y: 100,
            stagger: 0.1,
            duration: 1.2,
            ease: "expo.out",
            onComplete: () => calculateStaircase(true),
            scrollTrigger: {
                trigger: ".product-grid",
                start: "top 85%"
            }
        });
    }
    
    /* Filter */
    filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            const filter = btn.dataset.filter;
    
            filterBtns.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
    
            gsap.to(allCards, {
                scale: 0.5,
                opacity: 0,
                duration: 0.3,
                stagger: 0.02,
                onComplete: () => {
    
                    allCards.forEach(card => {
                        if (filter === 'all' || card.dataset.category === filter) {
                            gsap.set(card, { display: 'block' });
                        } else {
                            gsap.set(card, { display: 'none' });
                        }
                    });
    
                    calculateStaircase(false);
    
                    const visibleCards = Array.from(allCards).filter(c =>
                        window.getComputedStyle(c).display !== 'none'
                    );
    
                    gsap.to(visibleCards, {
                        scale: 1,
                        opacity: 1,
                        duration: 0.6,
                        stagger: 0.08,
                        ease: "back.out(1.2)",
                        onComplete: () => calculateStaircase(true)
                    });
                }
            });
        });
    });
    
    window.addEventListener('load', initEntrance);
    </script>