---
import "../../public/assets/style/contact-page.css";
import Navbar from "../components/navbar.astro";
import Footer from "../components/footer.astro";
import Layout from "../layouts/Layout.astro";
import ProductsDisplay from "../components/products-display.astro";
import PageHeadline from "../components/page-headline.astro";

import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout>
    <script
        is:inline
        src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"
    ></script>

    <script
        is:inline
        src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"
    ></script>
    <Navbar lang={lang} t={t} />

    <PageHeadline
        title='<h1 class="main-title">SELECCIÓN<br>PURO.</h1>
<p class="tagline">
Posiciona a Expo Lukus no como un "mayorista masivo", sino como una boutique seleccionada donde solo la mejor fruta pasa el corte.
</p>'
    />
    <br /><br />

    <ProductsDisplay lang={lang} t={t} />
    <br /><br /><br />
    <Footer lang={lang} t={t} />
</Layout>
