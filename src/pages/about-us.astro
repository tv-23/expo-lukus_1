---
import "../../public/assets/style/about-us-page.css";
import Navbar from "../components/navbar.astro";
import Layout from "../layouts/Layout.astro";
import PageHeadline from "../components/page-headline.astro";

import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout>
    <script
        is:inline
        src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"
    ></script>

    <script
        is:inline
        src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"
    ></script>
    <Navbar lang={lang} t={t} />

    <PageHeadline
        title='<h1 class="main-title">ROOTED.<br>GLOBAL.</h1><p class="tagline">Tells the story of the origin (Morocco) and the destination (Global) in one short, massive sentence.</p>'
    />

    <section class="story-section" id="storyPin">
        <div class="sticky-wrapper">
            <div class="container-70">
                <div class="content-flex">
                    <div class="text-column">
                        <!-- CHAPTER 1 -->
                        <div class="story-block" id="block1">
                            <span
                                style="color:var(--primary); font-weight:800; letter-spacing:4px; font-size: 12px;"
                                >HISTORY // 01</span
                            >
                            <h2>The Chetouan<br />Foundation.</h2>
                            <p>
                                Founded by the Chetouan family, Expo Lukus is
                                built on decades of hands-on experience in
                                supply and cold storage, preserving nature's
                                quality from the start.
                            </p>
                            <p>
                                Founded by the Chetouan family, Expo Lukus is
                                built on decades of hands-on experience in
                                supply and cold storage, preserving nature's
                                quality from the start.
                            </p>
                            <p>
                                We established a specialized company for
                                international export, leveraging robust
                                logistical resources to ensure compliance with
                                the most rigorous global standards.
                            </p>

                            <div class="mini-grid">
                                <div class="mini-stat">
                                    <h4>30+</h4><span>Years Experience</span>
                                </div>
                                <div class="mini-stat">
                                    <h4>100%</h4><span>Family Legacy</span>
                                </div>
                            </div>
                        </div>

                        <!-- CHAPTER 2 -->
                        <div class="story-block" id="block2">
                            <span
                                style="color:var(--primary); font-weight:800; letter-spacing:4px; font-size: 12px;"
                                >EXPANSION // 02</span
                            >
                            <h2>Going Global.</h2>
                            <p>
                                We established a specialized company for
                                international export, leveraging robust
                                logistical resources to ensure compliance with
                                the most rigorous global standards.
                            </p>
                            <div class="mini-grid">
                                <div class="mini-stat">
                                    <h4>Global</h4><span>Logistics</span>
                                </div>
                                <div class="mini-stat">
                                    <h4>ISO</h4><span>Standards</span>
                                </div>
                            </div>
                        </div>

                        <!-- CHAPTER 3 -->
                        <div class="story-block" id="block3">
                            <span
                                style="color:var(--primary); font-weight:800; letter-spacing:4px; font-size: 12px;"
                                >MISSION // 03</span
                            >
                            <h2>Beyond Profit.</h2>
                            <p>
                                Agriculture is a responsibility toward the land
                                and people. We build strong networks connecting
                                local producers with international markets,
                                maintaining trust at every stage.
                            </p>
                            <div class="mini-grid">
                                <div class="mini-stat">
                                    <h4>FairPay</h4><span>To Farmers</span>
                                </div>
                                <div class="mini-stat">
                                    <h4>Ethics</h4><span>Driven</span>
                                </div>
                            </div>
                        </div>

                        <!-- CHAPTER 4 -->
                        <div class="story-block" id="block4">
                            <span
                                style="color:var(--primary); font-weight:800; letter-spacing:4px; font-size: 12px;"
                                >BRIDGE // 04</span
                            >
                            <h2>The Trade Bridge.</h2>
                            <p>
                                Chetouan (Morocco) and Expo Lukus (Spain) form
                                an integrated trade bridge, facilitating smooth
                                exchange across domestic and foreign markets.
                            </p>
                            <div class="mini-grid">
                                <div class="mini-stat">
                                    <h4>Two Hubs</h4><span
                                        >Morocco & Spain</span>
                                </div>
                                <div class="mini-stat">
                                    <h4>Agility</h4><span>Supply Chain</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="portal-column">
                        <div class="portal-frame" id="portal">
                            <div class="portal-img-wrap" id="portalTrack">
                                <img
                                    src="https://images.unsplash.com/photo-1500382017468-9049fed747ef?q=80&w=1200"
                                    alt="Legacy"
                                />
                                <img
                                    src="https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?q=80&w=1200"
                                    alt="Expansion"
                                />
                                <img
                                    src="https://images.unsplash.com/photo-1610832958506-aa56368176cf?q=80&w=1200"
                                    alt="Farmers"
                                />
                                <img
                                    src="https://images.unsplash.com/photo-1494412519320-aa613dfb7738?q=80&w=1200"
                                    alt="Bridge"
                                />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <script>
        gsap.registerPlugin(ScrollTrigger);

        // This timeline creates the pinning room and handles the transitions
        let tl = gsap.timeline({
            scrollTrigger: {
                trigger: "#storyPin",
                start: "top top",
                end: "+=350%", // Total scroll distance (3.5 full screens)
                pin: true,
                scrub: 1.5,
                anticipatePin: 1,
            },
        });

        // Initial State fix
        gsap.set("#block1", { opacity: 1, y: 0 });

        // Transition 1: Block 1 out -> Block 2 in
        tl.to("#block1", { opacity: 0, y: -30, duration: 1 })
            .to(
                "#portalTrack",
                { yPercent: -25, ease: "power2.inOut", duration: 2 },
                "s1",
            )
            .to("#block2", { opacity: 1, y: 0, duration: 1 }, "s1+=0.5")

            // Transition 2: Block 2 out -> Block 3 in
            .to("#block2", { opacity: 0, y: -30, duration: 1, delay: 1 })
            .to(
                "#portalTrack",
                { yPercent: -50, ease: "power2.inOut", duration: 2 },
                "s2",
            )
            .to("#block3", { opacity: 1, y: 0, duration: 1 }, "s2+=0.5")

            // Transition 3: Block 3 out -> Block 4 in
            .to("#block3", { opacity: 0, y: -30, duration: 1, delay: 1 })
            .to(
                "#portalTrack",
                { yPercent: -75, ease: "power2.inOut", duration: 2 },
                "s3",
            )
            .to("#block4", { opacity: 1, y: 0, duration: 1 }, "s3+=0.5")

            // Final Buffer (ensures Chapter 4 stays visible briefly before unpinning)
            .to({}, { duration: 1.5 });

        // Parallax Label
        gsap.to(".bg-label", {
            xPercent: -15,
            scrollTrigger: {
                trigger: "#storyPin",
                start: "top bottom",
                end: "bottom top",
                scrub: true,
            },
        });

        // Refresh on load to ensure pinning height is calculated perfectly
        window.addEventListener("load", () => ScrollTrigger.refresh());
    </script>
</Layout>
