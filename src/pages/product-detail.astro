---
import "../../public/assets/style/product-detail.css"
import Navbar from "../components/navbar.astro";
import Layout from "../layouts/Layout.astro";

import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<Layout>
    <script
        is:inline
        src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"
    ></script>

    <script
        is:inline
        src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"
    ></script>
    <Navbar lang={lang} t={t} />
<div class="detail-wrapper">
    <!-- LEFT: GALLERY -->
    <div class="gallery-pane">
        <div class="main-fruit-wrap">
            <div class="bg-circle" id="circle"></div>
            <!-- High-res Mint Image -->
            <img src="https://pngimg.com/uploads/apple/apple_PNG12439.png" alt="Fresh Mint" class="fruit-img" id="productImg">
        </div>
    </div>

    <!-- RIGHT: INFO -->
    <div class="info-pane">
        <div class="ghost-bg" id="ghostText">FRESH</div>
        <span class="category-label">Export Quality</span>
        <h1>Mint</h1>
        
        <p class="description">
            Expo Lukus exports fresh mint in different export-grade packaging options, ensuring flexibility while maintaining freshness and high quality for international markets.
        </p>

        <div class="packaging-section">
            <h4>Packaging Options</h4>
            <div class="packaging-grid">
                <div class="pack-item">
                    <div class="pack-weight">100 G</div>
                    <div class="pack-detail">Bundle – 50 Pieces</div>
                </div>
                <div class="pack-item">
                    <div class="pack-weight">80 G</div>
                    <div class="pack-detail">Bundle – Variable Pieces</div>
                </div>
                <div class="pack-item">
                    <div class="pack-weight">70 G</div>
                    <div class="pack-detail">65 – 100 Pieces</div>
                </div>
            </div>
        </div>

        <a href="/contact" class="contact-trigger" id="magneticBtn">
            Place Enquiry
        </a>
    </div>
</div>

<script>
    gsap.registerPlugin(ScrollTrigger);

    // 1. Entrance Animation
    const tl = gsap.timeline();
    // tl.from("h1", { y: 100, opacity: 0, duration: 1, ease: "expo.out" })
    //   .from(".description", { y: 50, opacity: 0, duration: 0.8 }, "-=0.6")
    //   .from(".pack-item", { x: 50, opacity: 0, stagger: 0.15, duration: 0.8, ease: "back.out(1.7)" }, "-=0.4")
    //   .from("#productImg", { scale: 0.5, rotate: -20, opacity: 0, duration: 1.5, ease: "elastic.out(1, 0.75)" }, "0");

    // 2. Sticky Image Parallax & Rotation on Scroll
    gsap.to("#productImg", {
        rotation: 15,
        y: 50,
        scale: 1.1,
        scrollTrigger: {
            trigger: ".detail-wrapper",
            start: "top top",
            end: "bottom bottom",
            scrub: 1
        }
    });

    // 3. Ghost Text Parallax
    gsap.to("#ghostText", {
        x: 100,
        scrollTrigger: {
            trigger: ".detail-wrapper",
            scrub: 2
        }
    });

    // 4. Background Circle Pulse
    gsap.to("#circle", {
        scale: 1.2,
        opacity: 0.5,
        duration: 3,
        repeat: -1,
        yoyo: true,
        ease: "sine.inOut"
    });

    // 5. Magnetic Button Effect
    const btn = document.querySelector('#magneticBtn');
    btn.addEventListener('mousemove', (e) => {
        const rect = btn.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;

        gsap.to(btn, {
            x: x * 0.3,
            y: y * 0.3,
            duration: 0.5,
            ease: "power2.out"
        });
    });

    btn.addEventListener('mouseleave', () => {
        gsap.to(btn, { x: 0, y: 0, duration: 0.7, ease: "elastic.out(1, 0.75)" });
    });

</script>
</Layout>