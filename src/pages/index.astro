---
import Slider from "../components/home/slider.astro";
import About from "../components/home/about.astro";
import EuropeanGateway from "../components/home/european-gateway.astro";
import Navbar from "../components/navbar.astro";
import Footer from "../components/footer.astro";
import SectionTitle from "../components/section-title.astro";
import ProductsDisplayExport from "../components/products-display-export.astro";
import ProductsDisplayImport from "../components/products-display-import.astro";
import Certifications from "../components/home/certifications.astro";
import CTA from "../components/home/cta.astro";
import Layout from "../layouts/Layout.astro";

import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout>
    <Navbar lang={lang} t={t} />
    <script
        is:inline
        src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"
    ></script>

    <script
        is:inline
        src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"
    ></script>
 
    <Slider />
    <About lang={lang} t={t} />
    <br />
    <br />
    <SectionTitle
        title={t("products.headline")}
        subtitle={t("products.text")}
    />
    <br />
    <br />
    <ProductsDisplayExport lang={lang} t={t} />
    <br />
    <br />
    <SectionTitle
        title={t("productsI.headline")}
        subtitle={t("productsI.text")}
    />
    <br />
    <br />
    <ProductsDisplayImport lang={lang} t={t} />
    <br />
    <br />
    <EuropeanGateway lang={lang} t={t} />
    <SectionTitle
        title={t("certifications.headline")}
        subtitle={t("certifications.text")}
    />
    <Certifications />
    <CTA lang={lang} t={t} />
    <Footer lang={lang} t={t} />
</Layout>
