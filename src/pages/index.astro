---
import Slider from "../components/home/slider.astro";
import About from "../components/home/about.astro";
import Navbar from "../components/navbar.astro";
import Footer from "../components/footer.astro";
import SectionTitle from "../components/section-title.astro";
import ProductsDisplay from "../components/products-display.astro";
import Certifications from "../components/home/certifications.astro";
import CTA from "../components/home/cta.astro";
import Layout from "../layouts/Layout.astro";

import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout>
    <Navbar lang={lang} t={t} />
    <script
        is:inline
        src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"
    ></script>

    <script
        is:inline
        src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"
    ></script>

    <Slider />
    <About lang={lang} t={t} />
    <br />
    <br />
    <SectionTitle
        title={t("products.headline")}
        subtitle={t("products.text")}
    />
    <br />
    <br />
    <ProductsDisplay lang={lang} t={t} />
    <br />
    <SectionTitle title="Certifications" />
    <Certifications />
    <CTA />
    <Footer />
</Layout>
