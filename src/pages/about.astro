---
import "../../public/assets/style/about-us-page.css"
import Navbar from "../components/navbar.astro";
import Layout from "../layouts/Layout.astro";

import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<Layout>
    <script
        is:inline
        src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"
    ></script>

    <script
        is:inline
        src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"
    ></script>
    <Navbar lang={lang} t={t} />
    <div class="parallax-bg-text" id="bgText">CHETOUAN LEGACY</div>

    <div class="odyssey-wrapper">
        
        <section class="story-section" id="storySection">
            <div class="container-70">
                <div class="sticky-content">
                    
                    <div class="text-column">
                        <!-- Stage 1: The Family & Experience -->
                        <div class="story-block" id="block1">
                            <span style="color:var(--primary); font-weight:800; letter-spacing:4px;">HISTORY // 01</span>
                            <h2>A Foundation of<br>Expertise.</h2>
                            <p>Founded by the <strong>Chetouan family</strong>, Expo Lukus is built on decades of significant experience in fruit and vegetable distribution. From our roots in supply chains to premium cold storage, quality has always been our standard.</p>
                        </div>

                        <!-- Stage 2: The Expansion -->
                        <div class="story-block" id="block2">
                            <span style="color:var(--primary); font-weight:800; letter-spacing:4px;">EXPANSION // 02</span>
                            <h2>Going Global.</h2>
                            <p>Following our domestic success, we established a dedicated company specialized in exporting to international markets. We leverage years of hands-on logistical resources to ensure compliance with the most rigorous global standards.</p>
                        </div>

                        <!-- Stage 3: Vision & Farmers -->
                        <div class="story-block" id="block3">
                            <span style="color:var(--primary); font-weight:800; letter-spacing:4px;">MISSION // 03</span>
                            <h2>Beyond Profit.</h2>
                            <p>At Expo Lukus, we believe agriculture is a responsibility toward the land and its people. Our goal is to create new economic opportunities for local farmers, connecting them to a strong network of global trust.</p>
                        </div>

                        <!-- Stage 4: The Integrated Bridge -->
                        <div class="story-block" id="block4">
                            <span style="color:var(--primary); font-weight:800; letter-spacing:4px;">INTEGRATION // 04</span>
                            <h2>The Trade Bridge.</h2>
                            <p>Chetouan Import Export in Morocco and Expo Lukus in Spain form an integrated trade bridge. This synergy facilitates smooth exchange between local and international markets, enhancing access and growth for all partners.</p>
                        </div>
                    </div>

                    <div class="portal-column">
                        <div class="portal-frame" id="portal">
                            <div class="portal-img-wrap" id="portalTrack">
                                <!-- Farm/Roots -->
                                <img src="https://images.unsplash.com/photo-1500382017468-9049fed747ef?q=80&w=1200" alt="Legacy">
                                <!-- Global Shipping -->
                                <img src="https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?q=80&w=1200" alt="Global">
                                <!-- Community/Responsibility -->
                                <img src="https://images.unsplash.com/photo-1610832958506-aa56368176cf?q=80&w=1200" alt="Mission">
                                <!-- Morocco/Spain Map/Logistics vibe -->
                                <img src="https://images.unsplash.com/photo-1494412519320-aa613dfb7738?q=80&w=1200" alt="Bridge">
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </section>

        <!-- Final Reveal Section -->
        <section class="final-reveal">
            <div class="container-70">
                <div class="final-grid">
                    <div>
                        <h2 style="font-size: clamp(32px, 5vw, 60px); font-weight: 900; margin: 0; line-height: 1;">QUALITY AND TRUST<br><span style="color:var(--primary)">AT EVERY STAGE.</span></h2>
                    </div>
                    <div>
                        <p style="font-size: 18px; opacity: 0.7; line-height: 1.8;">Our dual presence in Morocco and Spain ensures development across the supply chain, creating greater growth opportunities in the import and export sector while maintaining a strong responsibility to the land.</p>
                    </div>
                </div>
            </div>
        </section>

    </div>

    <script>
        gsap.registerPlugin(ScrollTrigger);

        // 1. PINNED ODYSSEY TIMELINE (4 Stages)
        let tl = gsap.timeline({
            scrollTrigger: {
                trigger: "#storySection",
                start: "top top",
                end: "bottom bottom",
                scrub: 1.5,
                pin: true
            }
        });

        // Step 1: Block 1 Reveal
        tl.to("#block1", { opacity: 1, duration: 1 })
          .to("#block1", { opacity: 0, y: -40, duration: 1, delay: 0.5 })

        // Step 2: Portal Move + Block 2
        tl.to("#portalTrack", { yPercent: -25, duration: 2, ease: "power2.inOut" }, "step2")
          .to("#portal", { borderRadius: "40% 60% 70% 30% / 40%", duration: 1, repeat: 1, yoyo: true, ease: "sine.inOut" }, "step2")
          .to("#block2", { opacity: 1, y: 0, duration: 1 }, "step2+=0.5")
          .to("#block2", { opacity: 0, y: -40, duration: 1, delay: 0.5 })

        // Step 3: Portal Move + Block 3
        tl.to("#portalTrack", { yPercent: -50, duration: 2, ease: "power2.inOut" }, "step3")
          .to("#portal", { borderRadius: "60% 40% 30% 70% / 50%", duration: 1, repeat: 1, yoyo: true, ease: "sine.inOut" }, "step3")
          .to("#block3", { opacity: 1, y: 0, duration: 1 }, "step3+=0.5")
          .to("#block3", { opacity: 0, y: -40, duration: 1, delay: 0.5 })

        // Step 4: Portal Move + Block 4
        tl.to("#portalTrack", { yPercent: -75, duration: 2, ease: "power2.inOut" }, "step4")
          .to("#portal", { borderRadius: "35% 65% 65% 35% / 65% 35% 35% 65%", duration: 1, repeat: 1, yoyo: true, ease: "sine.inOut" }, "step4")
          .to("#block4", { opacity: 1, y: 0, duration: 1 }, "step4+=0.5");

        // 2. PARALLAX BG TEXT
        gsap.to("#bgText", {
            xPercent: -15,
            scrollTrigger: {
                trigger: ".odyssey-wrapper",
                start: "top bottom",
                end: "bottom top",
                scrub: 2
            }
        });

        // 3. MOUSE PORTAL TILT
        if(window.innerWidth > 1024) {
            document.addEventListener("mousemove", (e) => {
                const x = (e.clientX - window.innerWidth / 2) / 50;
                const y = (e.clientY - window.innerHeight / 2) / 50;
                gsap.to("#portal", { x: x, y: y, duration: 1.5, ease: "power2.out" });
            });
        }

        window.addEventListener('load', () => ScrollTrigger.refresh());
    </script>


</Layout>
